---
import "../sass/style.scss";

export interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Jason Lucas — Product Designer",
	description = "Product Designer based in London, UK. Bridging the gap between design and development.",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, shrink-to-fit=no"
		/>
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Three.js import map — required by main bundle and laptop animation module -->
		<script type="importmap" is:inline>
			{
				"imports": {
					"three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
					"three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
				}
			}
		</script>
	</head>

	<body>
		<div class="site" id="page">
			<slot />
		</div>

		<!-- GSAP -->
		<script
			is:inline
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
		></script>
		<script
			is:inline
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
		></script>

		<!-- SplitType — used by scroll-controls.js's text-split reveal -->
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/split-type@0.3.4/umd/index.min.js"
		></script>

		<!-- JS bundle -->
		<script is:inline src="/js/main.min.js"></script>

		<!-- Nav scroll indicator (depends on GSAP + ScrollTrigger) -->
		<script is:inline src="/js/nav-scroll-indicator.js"></script>

		<!-- Single home for all GSAP/ScrollTrigger scroll effects: active
			 section, text-split reveal, values card reveal, parallax shapes,
			 mouse parallax, nav marker -->
		<script type="module" is:inline>
			import { initScrollControls } from "/js/modules/scroll-controls.js";

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initScrollControls);
			} else {
				initScrollControls();
			}
		</script>
	</body>
</html>
